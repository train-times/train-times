{
  "name": "train-times",
  "version": "0.0.4",
  "license": "MIT",
  "author": "gameroman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/train-times/train-times.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#api": "./src/api/index.ts",
    "#api/*": "./src/api/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "fixture": "bun run ./scripts/generate-fixture",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "bun test",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.5",
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.22.13",
    "typescript": "7.0.2"
  }
}
